# ============================================
# Image Craft AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================

# --- Engine Selection ---
# Options: huggingface_cloud | local_diffusion
ENGINE=huggingface_cloud

# --- HuggingFace ---
# Get your token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_huggingface_token_here

# HuggingFace model for cloud inference
# See: https://huggingface.co/models?pipeline_tag=text-to-image
HF_MODEL=black-forest-labs/FLUX.1-schnell

# HuggingFace model for local inference
LOCAL_MODEL=stabilityai/sd-turbo

# --- Generation Defaults ---
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
DEFAULT_STEPS=20
DEFAULT_GUIDANCE_SCALE=7.5

# --- Paths (optional, defaults are fine for most users) ---
# IMAGE_OUTPUT_DIR=images
# LOG_DIR=logs

# --- Logging ---
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
